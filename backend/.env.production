# Server Configuration
PORT=5001
NODE_ENV=production

# Security Settings
FRONTEND_URL=https://your-production-domain.com # Production frontend URL'ini buraya yazın
MAX_FILE_SIZE=5242880 # Production'da 5MB limit
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=50 # Production'da daha sıkı limit 